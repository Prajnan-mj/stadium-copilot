  "faqs": [
    {"q": "What bags are allowed?", "a": "Clear bags up to 12\"×6\"×12\" or a small clutch no larger than 4.5\"×6.5\". One per person. Opaque bags and backpacks are not permitted.", "tags": ["bags","policy","entry"]},
    {"q": "Is there a no re-entry policy?", "a": "Yes. Once you exit the stadium there is no re-entry. Plan all concourse breaks accordingly.", "tags": ["reentry","exit","policy"]},
    {"q": "What is the weather like? Any heat advice?", "a": "July in Miami Gardens is hot and humid — heat index can exceed 40°C. The canopy covers seats but concourses are exposed. Drink water every 20 minutes. Free hydration stations are at all four concourse corners. If you feel unwell, go to First Aid or tell a steward.", "tags": ["weather","heat","humidity","hydration","health"]},
    {"q": "How do I get to the stadium?", "a": "Take the official FIFA match-day shuttle — runs from Aventura Mall transit hub and designated park-and-ride lots, direct and air-conditioned. Starts 3 hours before kickoff. Strongly recommended over driving.", "tags": ["transit","shuttle","arrival","transportation"]},
    {"q": "Where is the nearest hydration station?", "a": "Free cold-water hydration and refill stations are on all four concourses: NE, NW, SE, and SW. Look for the blue refill signs, or ask any steward. There's also a cooling misting zone at Gate C plaza.", "tags": ["water","hydration","refill","cooling","heat","bottle"]},
    {"q": "Where is First Aid?", "a": "First Aid stations are on the North and South concourses. For heat illness — dizziness, heavy sweating, confusion — move to shade immediately and alert the nearest yellow-vest steward.", "tags": ["first aid","medical","health","emergency","heat"]},
    {"q": "Where can I get help?", "a": "Fan Help Desks are on the NE and SW concourses. Staff in yellow vests are stationed throughout.", "tags": ["help","information","assistance","lost"]},
    {"q": "When should I arrive?", "a": "Gates open 2.5 hours before kickoff (12:30 for the 15:00 match). Arriving early avoids peak heat and entry queues.", "tags": ["arrival","timing","kickoff","gates"]},
    {"q": "Are there accessible restrooms?", "a": "Yes — accessible restrooms with elevator access on NE and SW concourses. Elevators at all four corners reach upper levels step-free.", "tags": ["accessible","restroom","wheelchair","disability"]},
    {"q": "Is there a quiet room for families or sensory needs?", "a": "Yes. The Family and Sensory Room is on Level 2, Section 210, and is air-conditioned. Access via the NE or NW elevator.", "tags": ["sensory","quiet","family","kids","disability","air conditioning"]},
    {"q": "What are prohibited items?", "a": "Outside food/drink, glass containers, cans, large umbrellas, selfie sticks, professional cameras with detachable lenses, drones, fireworks, and weapons.", "tags": ["prohibited","items","policy"]},
    {"q": "Where is the rideshare pickup?", "a": "Designated rideshare/taxi zones are at Gate 1 and Gate 5 plazas. Expect 45–75 minute waits post-match. The shuttle service is faster.", "tags": ["rideshare","uber","lyft","taxi","pickup"]},
    {"q": "Is the stadium wheelchair accessible?", "a": "Yes. Elevators at NE, NW, SE, and SW corners. Accessible seating throughout. Step-free routes on all concourses. Accessible restrooms on NE and SW concourses.", "tags": ["wheelchair","accessible","disability","elevator"]},
    {"q": "Can I bring a water bottle?", "a": "Empty reusable water bottles are allowed. Free refill stations are on all four concourses.", "tags": ["water bottle","refill","hydration"]},
    {"q": "Is smoking allowed?", "a": "No. Smoking and vaping are prohibited inside the stadium and on all grounds.", "tags": ["smoking","vaping"]},
    {"q": "Where is the cooling zone or shaded rest area?", "a": "A misting cooling zone is at Gate C plaza. The Family and Sensory Room (Level 2, Section 210) is air-conditioned. Hydration stations with shelter are at NE, NW, SE, SW concourses.", "tags": ["cooling","shade","heat","rest","misting","air conditioning"]}
  ]
}
