  "faqs": [
    {"q": "What bags are allowed?", "a": "Clear bags up to 12\"×6\"×12\", or a small clutch no larger than 4.5\"×6.5\". One clear bag per person. Prohibited: opaque backpacks, non-clear tote bags.", "tags": ["bags","policy","entry"]},
    {"q": "Can I re-enter the stadium once I leave?", "a": "No. Once you exit the stadium there is no re-entry. Plan all concourse visits accordingly.", "tags": ["reentry","exit","policy"]},
    {"q": "What items are prohibited?", "a": "Outside food/drink, glass containers, cans, large umbrellas, selfie sticks, professional cameras with detachable lenses, drones, fireworks, and weapons.", "tags": ["prohibited","policy","items"]},
    {"q": "How do I get to the stadium by train?", "a": "Take NJ Transit Meadowlands Rail from Secaucus Junction — direct on match days, ~8 minutes. This is the fastest and greenest option. Trains run frequently before kickoff and 90 minutes after the final whistle.", "tags": ["transit","train","rail","nj transit","arrival","departure"]},
    {"q": "What is the best way to get back to Manhattan after the match?", "a": "NJ Transit Meadowlands Rail to Secaucus Junction, then connect to Penn Station. Takes about 20 minutes total. Far faster than driving out of the lots post-match.", "tags": ["manhattan","departure","transit","train","after match"]},
    {"q": "Are there water bottle refill points?", "a": "Yes. Empty reusable water bottles are allowed. Hydration/water-refill stations are located at NE, NW, SE, and SW concourses.", "tags": ["water","refill","hydration","bottle"]},
    {"q": "Where can I get help if I need it?", "a": "Fan Help Desks are located on the NE and SW concourses. Staff in yellow vests can assist anywhere on the concourse.", "tags": ["help","information","lost","assistance"]},
    {"q": "When should I arrive?", "a": "Gates open 2.5 hours before kickoff. For the 15:00 final that means 12:30. Arriving early avoids peak entry congestion at T−60 minutes.", "tags": ["arrival","timing","kickoff","gates"]},
    {"q": "Are there accessible restrooms?", "a": "Yes — dedicated accessible restrooms are on the NE concourse (near elevator NE) and SW concourse (near elevator SW). Use the elevators to reach upper levels.", "tags": ["accessible","restroom","wheelchair","disability"]},
    {"q": "Where is first aid?", "a": "First Aid stations are on the North concourse near Gate C, and on the South concourse. For emergencies, flag the nearest yellow-vest steward immediately.", "tags": ["first aid","medical","emergency","health"]},
    {"q": "Is there a quiet or sensory room?", "a": "Yes. The Family and Sensory Room is on Level 2, Section 215. Accessible by elevator from the North concourse.", "tags": ["sensory","quiet","family","kids","disability"]},
    {"q": "Where do I go for lost and found?", "a": "Lost and found is handled at either Fan Help Desk on the NE or SW concourse. Items found after the event can be claimed via the venue hotline.", "tags": ["lost","found","lost and found"]},
    {"q": "Is there a prayer or quiet room?", "a": "A multi-faith quiet room is available on Level 2. Ask at the Fan Help Desk (NE concourse) for the exact location.", "tags": ["prayer","quiet room","religion","multi-faith"]},
    {"q": "Is smoking allowed?", "a": "No. Smoking and vaping are prohibited inside the stadium and on all stadium grounds.", "tags": ["smoking","vaping","tobacco"]},
    {"q": "Can I bring my children? Are there kids' facilities?", "a": "Yes. The Family and Sensory Room (Level 2, Section 215) is available. Children under 2 on a lap do not require a ticket. Check the Fan Help Desk for any lost-child protocol.", "tags": ["kids","children","family","baby"]},
    {"q": "What rideshare pickup zone do I use?", "a": "Rideshare and taxi pick-up is in Lot G on the north side. Expect 30–60 minute waits after the match. Rail is strongly recommended instead.", "tags": ["uber","lyft","rideshare","taxi","pickup","lot g"]},
    {"q": "Is the stadium accessible for wheelchair users?", "a": "Yes. Elevators are at NE, NW, SE, and SW corners. Accessible seating is available throughout. Step-free routes connect all concourses and gates. Accessible restrooms are on NE and SW concourses.", "tags": ["wheelchair","accessible","disability","elevator"]},
    {"q": "Can I bring an umbrella?", "a": "Small personal umbrellas are allowed. Large golf-style umbrellas and telescoping umbrellas are prohibited.", "tags": ["umbrella","rain","weather"]},
    {"q": "Where is the transit hub / NJ Transit platform?", "a": "The NJ Transit rail platform is at the north exit of the stadium — follow signs marked 'Meadowlands Rail' from the North concourse.", "tags": ["transit hub","nj transit","platform","train","rail","north exit"]}
  ]
}
